    "version": "0.2.0",
    "configurations": [
        

        {
            "name": "Python: _importtest (MINGW64)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/_importtest.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "C:\\msys64\\mingw64\\bin\\python.exe",
            "env": {
                "MSYSTEM": "MINGW64",
                "PATH": "C:\\msys64\\mingw64\\bin;${env:PATH}"
            }
        },
        {
            "name": "Python: Current File (MINGW64)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "C:\\msys64\\mingw64\\bin\\python.exe",
            "env": {
                "MSYSTEM": "MINGW64",
                "PATH": "C:\\msys64\\mingw64\\bin;${env:PATH}"
            }
        }
    ]
}
